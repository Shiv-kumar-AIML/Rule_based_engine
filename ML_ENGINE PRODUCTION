## 📊 DATABASE SCHEMA

```sql
-- drivers table
CREATE TABLE drivers (
    driver_id       UUID PRIMARY KEY,
    name            VARCHAR(255) NOT NULL,
    latitude        DECIMAL(10, 8) NOT NULL,
    longitude       DECIMAL(11, 8) NOT NULL,
    rating          DECIMAL(2, 1) DEFAULT 0,
    completion_rate DECIMAL(3, 2) DEFAULT 0,
    vehicle_type    VARCHAR(50) NOT NULL,
    is_available    BOOLEAN DEFAULT true,
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- loads table
CREATE TABLE loads (
    load_id         UUID PRIMARY KEY,
    pickup_lat      DECIMAL(10, 8) NOT NULL,
    pickup_lng      DECIMAL(11, 8) NOT NULL,
    dropoff_lat     DECIMAL(10, 8) NOT NULL,
    dropoff_lng     DECIMAL(11, 8) NOT NULL,
    weight_kg       DECIMAL(10, 2) NOT NULL,
    urgency         VARCHAR(20) DEFAULT 'medium',
    status          VARCHAR(20) DEFAULT 'pending',
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- historical_matches table (for ML training)
CREATE TABLE historical_matches (
    match_id        UUID PRIMARY KEY,
    driver_id       UUID REFERENCES drivers(driver_id),
    load_id         UUID REFERENCES loads(load_id),
    distance_km     DECIMAL(10, 2) NOT NULL,
    driver_rating   DECIMAL(2, 1) NOT NULL,
    completion_rate DECIMAL(3, 2) NOT NULL,
    was_accepted    BOOLEAN NOT NULL,           -- Target for ML
    response_time   INTEGER,                     -- Seconds
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Indexes for performance
CREATE INDEX idx_drivers_available ON drivers(is_available);
CREATE INDEX idx_drivers_location ON drivers(latitude, longitude);
CREATE INDEX idx_loads_status ON loads(status);
CREATE INDEX idx_matches_created ON historical_matches(created_at);
```

