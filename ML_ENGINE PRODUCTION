# 🤖 5) ML SERVICE (AUTO-LOAD)

## 📌 `ml_service/predict.py`

```python
import pickle, os

MODEL_PATH = "/storage/model.pkl"

model = None
last_modified = None

def load_model():
    global model, last_modified
    
    current = os.path.getmtime(MODEL_PATH)
    
    if last_modified != current:
        with open(MODEL_PATH, "rb") as f:
            model = pickle.load(f)
        last_modified = current
        print("🔄 New model loaded")

def predict(data):
    load_model()

    features = [[
        data["distance"],
        data["rating"],
        data["completion"]
    ]]

    return float(model.predict_proba(features)[0][1])
```


